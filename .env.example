# Copy to .env.local and fill in. .env.local is gitignored.

# Greeting in the header ("Good morning, ${VITE_USER_NAME}")
VITE_USER_NAME=friend

# Open-Meteo coords for the ClockWeather widget.
# Find yours at https://open-meteo.com/  (or geocode any city).
# Defaults to Greenwich, UK.
VITE_WEATHER_LAT=51.4779
VITE_WEATHER_LON=-0.0015
VITE_WEATHER_LOCATION=Greenwich
